# Copy this file to .env and fill in real values.
# .env itself is git-ignored — never commit real credentials.

APP_NAME="RAM YUM - Facilities & Administrative Management"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=capstone_shared_db
DB_USER=root
DB_PASS=

# Team 8 table prefix (already baked into schema.sql, kept here for reference)
DB_TEAM8_PREFIX=team8_

# TEMPORARY AUTH (see login.php / logout.php / docs/Auth.md)
# When true, skips the login form entirely and auto-logs in as the seeded
# "Dev Tester" (user_id 1). Leave FALSE by default now that real login.php
# exists — flip to true only for quick throwaway testing.
AUTH_DEV_BYPASS=false

# Upload limits
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=public/uploads
